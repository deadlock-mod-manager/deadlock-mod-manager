<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>dev.stormix.deadlock-mod-manager</id>

  <name>Deadlock Mod Manager</name>
  <summary>A mod manager for the Valve game Deadlock</summary>
  <developer id="dev.stormix">
    <name>Stormix</name>
  </developer>

  <metadata_license>FSFAP</metadata_license>
  <project_license>GPL-3.0-only</project_license>

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
  </supports>

  <description>
    <p>
      Deadlock Mod Manager lets you discover, install, and manage mods for
      Valve's Deadlock without touching game files manually. Browse mods, install
      them in one click, toggle them on and off, and manage load order when mods
      conflict.
    </p>
    <p>Features include:</p>
    <ul>
      <li>Browse, search, and filter mods by category, popularity, and rating</li>
      <li>One-click mod installation with automatic file management</li>
      <li>Enable and disable mods without uninstalling</li>
      <li>Drag-and-drop load order management for conflicting mods</li>
      <li>Automatic mod updates</li>
      <li>Local addon analysis to detect and match existing mods</li>
      <li>Multi-language support with community translations</li>
      <li>Crosshair preview and import</li>
      <li>Profile management and sharing for mod collections</li>
    </ul>
  </description>

  <launchable type="desktop-id">deadlock-modmanager.desktop</launchable>

  <url type="homepage">https://deadlockmods.app</url>
  <url type="bugtracker">https://github.com/deadlock-mod-manager/deadlock-mod-manager/issues</url>
  <url type="vcs-browser">https://github.com/deadlock-mod-manager/deadlock-mod-manager</url>

  <screenshots>
    <screenshot type="default">
      <caption>Main mod library view</caption>
      <image>https://raw.githubusercontent.com/deadlock-mod-manager/deadlock-mod-manager/main/docs/assets/screenshot-library.png</image>
    </screenshot>
  </screenshots>

  <provides>
    <binary>deadlock-modmanager</binary>
  </provides>

  <releases>
    <release version="0.15.0" date="2026-02-26">
      <url type="details">https://github.com/deadlock-mod-manager/deadlock-mod-manager/releases/tag/v0.15.0</url>
      <description>
        <p>See the full release notes at https://github.com/deadlock-mod-manager/deadlock-mod-manager/releases</p>
      </description>
    </release>
    <release version="0.14.1" date="2026-01-01">
      <url type="details">https://github.com/deadlock-mod-manager/deadlock-mod-manager/releases/tag/v0.14.1</url>
      <description>
        <p>Bug fixes and stability improvements.</p>
      </description>
    </release>
  </releases>

  <content_rating type="oars-1.1" />
</component>
