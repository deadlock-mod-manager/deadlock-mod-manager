# Maintainer: stormix <contact@stormix.co>
pkgname=deadlock-modmanager
_pkgver=0.15.0
pkgver=${_pkgver}
pkgrel=1
pkgdesc="A mod manager for the Valve game Deadlock, built with Tauri"
arch=('x86_64')
url="https://github.com/deadlock-mod-manager/deadlock-mod-manager"
license=('GPL-3.0-only')
depends=(
    'webkit2gtk-4.1'
    'gtk3'
    'libappindicator-gtk3'
    'xdg-utils'
)
options=('!strip')
source=("${pkgname}-${pkgver}.deb::https://github.com/deadlock-mod-manager/deadlock-mod-manager/releases/download/v${_pkgver}/deadlock-mod-manager_${_pkgver}_amd64.deb")
sha256sums=('SKIP')

package() {
    cd "${srcdir}"

    # Extract the .deb archive
    ar x "${pkgname}-${pkgver}.deb"
    tar -xf data.tar.* -C "${pkgdir}/"

    # Patch .desktop to declare URI scheme handlers (avoids side-effect xdg-mime calls)
    local _desktop="${pkgdir}/usr/share/applications/deadlock-mod-manager.desktop"
    if ! grep -q '^MimeType=' "${_desktop}"; then
        echo 'MimeType=x-scheme-handler/deadlock-mod-manager;x-scheme-handler/deadlock-modmanager;x-scheme-handler/dlmm;' >> "${_desktop}"
    fi
}
