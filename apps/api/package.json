{
  "name": "@deadlock-mods/api",
  "version": "3.0.0",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsgo --noEmit --skipLibCheck",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "start": "dotenv -e ../../.env -- bun run --preload ./src/instrument.ts ./src/index.ts",
    "dev": "dotenv -e ../../.env -- bun run --watch --preload ./src/instrument.ts ./src/index.ts",
    "test:mod-events": "dotenv -e ../../.env -- bun run ./src/scripts/test-mod-events.ts",
    "calculate-mod-sizes": "dotenv -e ../../.env -- bun run ./src/scripts/calculate-mod-sizes.ts",
    "sync-mods": "dotenv -e ../../.env -- bun run ./src/scripts/sync-mods.ts",
    "set-mod-overrides": "dotenv -e ../../.env -- bun run ./src/scripts/set-mod-overrides.ts",
    "desktop:dev": "pnpm dev",
    "version:generate": "genversion -f -p ./package.json --es6 ./src/version.ts"
  },
  "dependencies": {
    "@better-fetch/fetch": "^1.1.21",
    "@deadlock-mods/common": "workspace:*",
    "@deadlock-mods/database": "workspace:*",
    "@deadlock-mods/distributed-lock": "workspace:*",
    "@deadlock-mods/feature-flags": "workspace:*",
    "@deadlock-mods/instrumentation": "workspace:*",
    "@deadlock-mods/kv-parser": "workspace:*",
    "@deadlock-mods/logging": "workspace:*",
    "@deadlock-mods/queue": "workspace:*",
    "@deadlock-mods/relay-client": "workspace:*",
    "@deadlock-mods/shared": "workspace:*",
    "@deadlock-mods/vpk-parser": "workspace:*",
    "@hono/prometheus": "^1.0.2",
    "@hono/sentry": "^1.2.2",
    "@mjackson/lazy-file": "^3.4.0",
    "@orpc/client": "^1.13.13",
    "@orpc/openapi": "^1.13.13",
    "@orpc/server": "^1.13.13",
    "@orpc/zod": "^1.13.13",
    "@sentry/node": "catalog:",
    "croner": "^9.1.0",
    "dotenv-cli": "^7.4.4",
    "genversion": "^3.2.0",
    "hono": "^4.12.14",
    "ioredis": "^5.10.1",
    "neverthrow": "^8.2.0",
    "prom-client": "^15.1.3",
    "rss-parser": "^3.13.0",
    "tslog": "^4.10.2",
    "uuid": "^11.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@deadlock-mods/typescript-config": "workspace:*",
    "@types/bun": "^1.3.11",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "@typescript/native-preview": "catalog:",
    "tsdown": "^0.14.2"
  }
}
