{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "ui": "tui",
  "globalPassThroughEnv": [
    "PATH",
    "PKG_CONFIG_PATH",
    "PKG_CONFIG_LIBDIR",
    "LD_LIBRARY_PATH",
    "NIX_STORE",
    "NIX_PROFILES",
    "RUST_SRC_PATH",
    "CARGO_HOME"
  ],
  "tasks": {
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "db:push": {},
    "db:seed": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "desktop:dev": {
      "cache": false,
      "persistent": true
    },
    "//#lint": {},
    "//#format": {
      "cache": false
    },
    "version:generate": {
      "cache": false
    }
  },
  "globalEnv": ["BETTERSTACK_API_KEY", "DATABASE_URL"]
}
