{
  "name": "@deadlock-mods/root",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "db:push": "turbo run db:push",
    "db:seed": "turbo run db:seed",
    "api:dev": "pnpm --filter api dev",
    "www:dev": "pnpm --filter www dev",
    "dev": "turbo run dev --concurrency=20",
    "desktop:dev": "pnpm --filter desktop dev",
    "desktop:build": "pnpm --filter desktop tauri build",
    "desktop:build:dev": "pnpm --filter desktop build:dev",
    "docs:dev": "pnpm --filter docs dev",
    "impeccable": "impeccable",
    "impeccable:detect": "impeccable detect --fast apps/desktop/src",
    "impeccable:detect:json": "impeccable detect --fast --json apps/desktop/src",
    "impeccable:skills:update": "impeccable skills update",
    "vpk-parser:build": "pnpm --filter vpk-parser build",
    "dmp-parser:build": "pnpm --filter dmp-parser build",
    "dmp-parser": "pnpm --filter dmp-parser run parse",
    "hero-parser": "pnpm --filter @deadlock-mods/hero-parser cli --",
    "docker:api:build": "docker build -f apps/api/Dockerfile -t deadlock-api .",
    "docker:api:run": "docker run --rm -p 9000:9000 --env-file .env deadlock-api",
    "docker:api:dev": "docker compose up api --build",
    "docker:api:stop": "docker compose down",
    "docker:api:logs": "docker compose logs -f api",
    "docker:mirror-service:build": "docker build -f apps/mirror-service/Dockerfile -t deadlock-mirror-service .",
    "docker:mirror-service:run": "docker run --rm -p 3002:3002 --env-file .env deadlock-mirror-service",
    "docker:mirror-service:dev": "docker compose up mirror-service --build",
    "docker:mirror-service:stop": "docker compose down",
    "docker:mirror-service:logs": "docker compose logs -f mirror-service",
    "docker:www:build": "docker build -f apps/www/Dockerfile -t deadlock-www .",
    "docker:www:run": "docker run --rm -p 3000:3000 --env-file .env deadlock-www",
    "docker:www:dev": "docker compose up www --build",
    "docker:www:stop": "docker compose down",
    "docker:www:logs": "docker compose logs -f www",
    "docker": "docker compose up -d",
    "format": "oxfmt .",
    "lint": "oxlint .",
    "format:fix": "oxfmt . --write",
    "lint:fix": "oxlint . --fix",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "generate-lang-table": "bun run scripts/generate-language-table.ts --update-readme",
    "publish-packages": "turbo run build && changeset version",
    "upgrade-dependencies": "bun run scripts/upgrade-dependencies.ts",
    "version:generate": "turbo run version:generate",
    "version:nightly": "bun run scripts/update-nightly-version.ts",
    "release-notes": "bun run scripts/generate-release-notes.ts",
    "version:without-desktop": "bun run scripts/version-without-desktop.ts",
    "db:studio": "pnpm --filter database db:studio",
    "db:migrate": "pnpm --filter database db:migrate",
    "db:generate": "pnpm --filter database db:generate",
    "db:migrations:reset": "git fetch origin && pnpm -s rimraf packages/database/drizzle && git restore --source origin/main -- packages/database/drizzle",
    "clean": "rimraf --glob **/node_modules",
    "aur:test": "bash scripts/test-aur-packages.sh"
  },
  "dependencies": {
    "@changesets/cli": "^2.30.0"
  },
  "devDependencies": {
    "@typescript/native-preview": "catalog:",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^7.4.4",
    "impeccable": "2.1.9",
    "lefthook": "^1.13.6",
    "oxfmt": "0.50.0",
    "oxlint": "1.65.0",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.14",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f"
}
